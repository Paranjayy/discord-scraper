{
  "manifest_version": 3,
  "name": "Discord Media Scraper",
  "version": "1.1.0",
  "description": "Scrape and download images, videos, zip files, and text from Discord channels",
  "permissions": [
    "storage",
    "webRequest",
    "tabs",
    "downloads"
  ],
  "host_permissions": ["*://discord.com/*"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["jszip.min.js", "background.js"]
  },
  "web_accessible_resources": [
    {
      "resources": ["viewer/index.html"],
      "matches": ["*://discord.com/*"]
    }
  ]
}
